# Obrigatório em produção (Vercel). Em dev com FLASK_DEBUG=True, pode ficar vazio
# (usa fallback interno) ou use dev-only-change-in-production.
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-change-in-production

FLASK_DEBUG=True

# E-mail (Flask-Mail) — usado no formulário de contato
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=jdevscommunity@protonmail.com
